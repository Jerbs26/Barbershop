<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/topNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#CC000000"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:gravity="center_vertical"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:paddingTop="@dimen/nav_padding"
            android:paddingBottom="@dimen/nav_padding"
            android:text="Home"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/nav_text_size"
            android:textStyle="bold"/>

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:background="#55FFFFFF"/>

        <TextView
            android:id="@+id/navAbout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:paddingTop="@dimen/nav_padding"
            android:paddingBottom="@dimen/nav_padding"
            android:text="About Us"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/nav_text_size"
            android:textStyle="bold"/>

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:background="#55FFFFFF"/>

        <TextView
            android:id="@+id/navServices"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:paddingTop="@dimen/nav_padding"
            android:paddingBottom="@dimen/nav_padding"
            android:text="Services"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/nav_text_size"
            android:textStyle="bold"/>

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:background="#55FFFFFF"/>

        <TextView
            android:id="@+id/navContact"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:paddingTop="@dimen/nav_padding"
            android:paddingBottom="@dimen/nav_padding"
            android:text="Contact Us"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/nav_text_size"
            android:textStyle="bold"/>

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:background="#55FFFFFF"/>

        <TextView
            android:id="@+id/navLogin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:paddingTop="@dimen/nav_padding"
            android:paddingBottom="@dimen/nav_padding"
            android:text="Log In"
            android:textColor="#FFEB3B"
            android:textSize="@dimen/nav_text_size"
            android:textStyle="bold"/>

    </LinearLayout>

    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topNav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A1A">

            <FrameLayout
                android:id="@+id/sectionHome"
                android:layout_width="match_parent"
                android:layout_height="700dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Barbershop hero image"
                    android:src="@drawable/shopbarbers"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="sans-serif-black"
                    android:text="THE URBAN&#10;RAZOR"
                    android:textAlignment="center"
                    android:textColor="#FFD700"
                    android:textSize="@dimen/hero_text_size"
                    android:textStyle="bold|italic"
                    android:background="#66000000"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"/>

            </FrameLayout>

            <LinearLayout
                android:id="@+id/sectionAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#222222"
                android:paddingTop="48dp"
                android:paddingBottom="48dp"
                android:paddingStart="32dp"
                android:paddingEnd="32dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_gravity="center"
                    android:layout_marginBottom="10dp">

                    <View
                        android:layout_width="28dp"
                        android:layout_height="1.5dp"
                        android:background="#FFEB3B"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OUR STORY"
                        android:textColor="#FFEB3B"
                        android:textSize="11sp"
                        android:letterSpacing="0.36"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"/>

                    <View
                        android:layout_width="28dp"
                        android:layout_height="1.5dp"
                        android:background="#FFEB3B"
                        android:layout_marginStart="10dp"/>

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="ABOUT US"
                    android:textColor="#FFEB3B"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold|italic"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_gravity="center"
                    android:layout_marginBottom="20dp">

                    <View
                        android:layout_width="48dp"
                        android:layout_height="1dp"
                        android:background="#FFEB3B"
                        android:layout_marginEnd="10dp"/>

                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:background="@drawable/diamond_yellow"
                        android:rotation="45"/>

                    <View
                        android:layout_width="48dp"
                        android:layout_height="1dp"
                        android:background="#FFEB3B"
                        android:layout_marginStart="10dp"/>

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.7"
                    android:text="Welcome to The Urban Razor, where tradition meets style. Our expert barbers are dedicated to giving you the perfect cut every time."
                    android:textColor="#C4A97D"
                    android:textSize="@dimen/body_text_size"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginBottom="32dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/border_box_light"
                    android:layout_marginBottom="32dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10+"
                            android:textColor="#FFD700"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="YEARS"
                            android:textColor="#C4A97D"
                            android:textSize="10sp"
                            android:letterSpacing="0.2"
                            android:fontFamily="sans-serif-condensed"/>

                    </LinearLayout>

                    <View
                        android:layout_width="0.5dp"
                        android:layout_height="match_parent"
                        android:background="#C4A97D"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5K+"
                            android:textColor="#FFD700"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CLIENTS"
                            android:textColor="#C4A97D"
                            android:textSize="10sp"
                            android:letterSpacing="0.2"
                            android:fontFamily="sans-serif-condensed"/>

                    </LinearLayout>

                    <View
                        android:layout_width="0.5dp"
                        android:layout_height="match_parent"
                        android:background="#C4A97D"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8"
                            android:textColor="#FFD700"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BARBERS"
                            android:textColor="#C4A97D"
                            android:textSize="10sp"
                            android:letterSpacing="0.2"
                            android:fontFamily="sans-serif-condensed"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionServices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A1A1A"
                android:paddingTop="@dimen/section_padding"
                android:paddingBottom="@dimen/section_padding"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:letterSpacing="0.1"
                    android:text="OUR SERVICES"
                    android:textColor="#FFEB3B"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold|italic"/>

                <View
                    android:layout_width="60dp"
                    android:layout_height="2dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="24dp"
                    android:background="#FFEB3B"/>

                <LinearLayout
                    android:id="@+id/cardHaircut"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp"
                    android:background="@drawable/service_card_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">



                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HAIRCUT"
                            android:textColor="#FFEB3B"
                            android:textSize="@dimen/card_title_size"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Classic and modern haircuts tailored to your style."
                            android:textColor="#AAAAAA"
                            android:textSize="@dimen/card_body_size"
                            android:lineSpacingMultiplier="1.4"/>

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardShaving"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp"
                    android:background="@drawable/service_card_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">


                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SHAVING"
                            android:textColor="#FFEB3B"
                            android:textSize="@dimen/card_title_size"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Traditional hot towel shave for a smooth finish."
                            android:textColor="#AAAAAA"
                            android:textSize="@dimen/card_body_size"
                            android:lineSpacingMultiplier="1.4"/>

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardStyling"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp"
                    android:background="@drawable/service_card_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HAIR STYLING"
                            android:textColor="#FFEB3B"
                            android:textSize="@dimen/card_title_size"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Professional styling for any occasion."
                            android:textColor="#AAAAAA"
                            android:textSize="@dimen/card_body_size"
                            android:lineSpacingMultiplier="1.4"/>

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardColoring"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp"
                    android:background="@drawable/service_card_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HAIR COLORING"
                            android:textColor="#FFEB3B"
                            android:textSize="@dimen/card_title_size"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Expert coloring services to match your personality."
                            android:textColor="#AAAAAA"
                            android:textSize="@dimen/card_body_size"
                            android:lineSpacingMultiplier="1.4"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionReviews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#222222"
                android:paddingTop="48dp"
                android:paddingBottom="48dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:letterSpacing="0.1"
                    android:text="CUSTOMER REVIEWS"
                    android:textColor="#FFEB3B"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold|italic"/>

                <View
                    android:layout_width="60dp"
                    android:layout_height="2dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:background="#FFEB3B"/>

                <LinearLayout
                    android:id="@+id/avgRatingRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/tvAvgScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="0.0"
                        android:textColor="#FFEB3B"
                        android:textSize="36sp"
                        android:textStyle="bold"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvAvgStars"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="☆☆☆☆☆"
                            android:textColor="#FFEB3B"
                            android:textSize="18sp"/>

                        <TextView
                            android:id="@+id/tvTotalReviews"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 reviews"
                            android:textColor="#AAAAAA"
                            android:textSize="12sp"/>

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/reviewsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <Button
                        android:id="@+id/btnPrevReview"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:backgroundTint="#FFEB3B"
                        android:text="◀ Prev"
                        android:textAllCaps="false"
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:cornerRadius="8dp"/>

                    <TextView
                        android:id="@+id/tvPageIndicator"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Page 1 of 1"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"/>

                    <Button
                        android:id="@+id/btnNextReview"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:backgroundTint="#FFEB3B"
                        android:text="Next ▶"
                        android:textAllCaps="false"
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:cornerRadius="8dp"/>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A1A1A"
                android:paddingTop="@dimen/section_padding"
                android:paddingBottom="@dimen/section_padding"
                android:paddingStart="@dimen/section_padding"
                android:paddingEnd="@dimen/section_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:letterSpacing="0.1"
                    android:text="CONTACT US"
                    android:textColor="#FFEB3B"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold|italic"/>

                <View
                    android:layout_width="60dp"
                    android:layout_height="2dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="24dp"
                    android:background="#FFEB3B"/>

                <LinearLayout
                    android:id="@+id/contactFacebook"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:padding="@dimen/card_padding"
                    android:background="@drawable/contact_card_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_facebook"
                        android:contentDescription="Facebook"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FACEBOOK"
                            android:textColor="#FFEB3B"
                            android:textSize="@dimen/card_title_size"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UrbanRazor"
                            android:textColor="#AAAAAA"
                            android:textSize="@dimen/card_body_size"/>

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/contactPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:padding="@dimen/card_padding"
                    android:background="@drawable/contact_card_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_phone"
                        android:contentDescription="Phone"
                        app:tint="#42E90A"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MOBILE NUMBER"
                            android:textColor="#FFEB3B"
                            android:textSize="@dimen/card_title_size"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+63 909 407 7216"
                            android:textColor="#AAAAAA"
                            android:textSize="@dimen/card_body_size"/>

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/contactLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:padding="@dimen/card_padding"
                    android:background="@drawable/contact_card_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_location"
                        android:contentDescription="Location"
                        app:tint="#F80431"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LOCATION"
                            android:textColor="#FFEB3B"
                            android:textSize="@dimen/card_title_size"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7021 Balimbing St, Comembo, Taguig City, Metro Manila"
                            android:textColor="#AAAAAA"
                            android:textSize="@dimen/card_body_size"/>

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <WebView
                        android:id="@+id/mapWebView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/contact_card_bg"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>