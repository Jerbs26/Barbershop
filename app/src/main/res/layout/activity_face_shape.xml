<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#2C2C2C"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            app:tint="#FFEB3B" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✂  Haircut Finder"
            android:textColor="#FFEB3B"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <View
            android:layout_width="40dp"
            android:layout_height="40dp"/>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/cameraContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <View
            android:id="@+id/faceGuideOverlay"
            android:layout_width="220dp"
            android:layout_height="280dp"
            android:layout_gravity="center"
            android:background="@drawable/face_guide_oval"
            android:alpha="0.6"/>

        <TextView
            android:id="@+id/tvInstruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="Position your face inside the oval"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="#88000000"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"/>

        <TextView
            android:id="@+id/tvFaceDetected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="12dp"
            android:text="● Face Detected"
            android:textColor="#4CAF50"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="#CC1A1A1A"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:visibility="gone"/>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/captureRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#2C2C2C"
        android:gravity="center"
        android:padding="16dp">

        <Button
            android:id="@+id/btnFlipCamera"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginEnd="24dp"
            android:text="🔄 Flip"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:backgroundTint="#5A5A5A"
            app:cornerRadius="24dp"/>

        <Button
            android:id="@+id/btnCapture"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:text="📸"
            android:textSize="28sp"
            android:backgroundTint="#FFEB3B"
            app:cornerRadius="36dp"/>

        <Button
            android:id="@+id/btnRetake"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="24dp"
            android:text="↩ Retake"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:backgroundTint="#5A5A5A"
            android:visibility="gone"
            app:cornerRadius="24dp"/>
    </LinearLayout>

    <ScrollView
        android:id="@+id/resultsPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0"
        android:background="#1A1A1A"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#2C2C2C"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvFaceShapeEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="40sp"
                    android:layout_marginEnd="16dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YOUR FACE SHAPE"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/tvFaceShapeResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Oval"
                        android:textColor="#FFEB3B"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvFaceShapeDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Well-balanced proportions"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="RECOMMENDED HAIRCUTS"
                android:textColor="#FFEB3B"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/haircutCard1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#2C2C2C"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/tvHaircut1Icon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="✂"
                    android:textSize="26sp"
                    android:textColor="#FFEB3B"
                    android:gravity="center"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvHaircut1Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Classic Taper"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvHaircut1Desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clean sides with length on top"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvHaircut1Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:text="⭐ Top Pick"
                    android:textColor="#FFEB3B"
                    android:textSize="11sp"
                    android:background="#33FFEB3B"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/haircutCard2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#2C2C2C"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/tvHaircut2Icon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="✂"
                    android:textSize="26sp"
                    android:textColor="#FFEB3B"
                    android:gravity="center"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvHaircut2Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pompadour"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvHaircut2Desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Volume on top, swept back"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/haircutCard3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#2C2C2C"
                android:padding="14dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvHaircut3Icon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="✂"
                    android:textSize="26sp"
                    android:textColor="#FFEB3B"
                    android:gravity="center"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvHaircut3Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Crew Cut"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvHaircut3Desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Short and neat all around"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnBookFromResult"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Book This Style Now"
                android:textAllCaps="false"
                android:textColor="#1A1A1A"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#FFEB3B"
                app:cornerRadius="8dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>