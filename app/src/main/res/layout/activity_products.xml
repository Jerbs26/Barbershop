<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".user.Products">

    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="@dimen/sidebar_width"
        android:layout_height="0dp"
        android:background="#3A3A3A"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/profileCircle"
                android:layout_width="@dimen/sidebar_profile_size"
                android:layout_height="@dimen/sidebar_profile_size"
                android:background="@drawable/circle_background_removebg_preview__1_"
                android:gravity="center"
                android:text="AR"
                android:textColor="#3A3A3A"
                android:textSize="@dimen/main_title_size"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/userEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="user@gmail.com"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/sidebar_email_size"/>

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnNewBooking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:backgroundTint="@android:color/transparent"
            android:drawablePadding="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="New Booking"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            app:drawableStartCompat="@drawable/ic_calendar"
            app:drawableTint="@android:color/white" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnBarbers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:backgroundTint="@android:color/transparent"
            android:drawablePadding="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Barbers"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/sidebar_text_size"
            app:drawableStartCompat="@drawable/ic_barber"
            app:drawableTint="@color/white" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnServices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:backgroundTint="@android:color/transparent"
            android:drawablePadding="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Services"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/sidebar_text_size"
            app:drawableStartCompat="@drawable/ic_scissors"
            app:drawableTint="@color/white" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnProducts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:backgroundTint="@android:color/transparent"
            android:drawablePadding="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Products"
            android:textAllCaps="false"
            android:textColor="#FFEB3B"
            android:textSize="@dimen/sidebar_text_size"
            app:drawableStartCompat="@drawable/ic_products"
            app:drawableTint="#F4F6F4" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:backgroundTint="@android:color/transparent"
            android:drawablePadding="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="History"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/sidebar_text_size"
            app:drawableStartCompat="@drawable/ic_history"
            app:drawableTint="#FFFFFF" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRatings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:backgroundTint="@android:color/transparent"
            android:drawablePadding="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Ratings"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/sidebar_text_size"
            app:drawableStartCompat="@drawable/ic_star"
            app:drawableTint="#FFFFFF" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#C62828"
            android:drawablePadding="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Logout"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/sidebar_text_size"
            app:drawableStartCompat="@drawable/ic_logout"
            app:drawableTint="#FFFFFF" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/contentArea"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="?attr/colorSurface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Fixed header row: title on left, Cart button on right -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Our Products"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/main_title_size"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnCart"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/small_button_height"
                android:backgroundTint="#FFEB3B"
                android:drawableStart="@drawable/ic_cart"
                android:drawablePadding="6dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Cart"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textSize="@dimen/sidebar_text_size"
                app:cornerRadius="20dp"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutline"
            android:alpha="0.15"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/productsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"/>

        </ScrollView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>