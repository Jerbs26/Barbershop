<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="?attr/colorSurface"
    tools:context=".user.Dashboard">

    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="@dimen/sidebar_width"
        android:layout_height="match_parent"
        android:background="#3A3A3A"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/profileCircle"
                android:layout_width="@dimen/sidebar_profile_size"
                android:layout_height="@dimen/sidebar_profile_size"
                android:background="@drawable/circle_background_removebg_preview__1_"
                android:gravity="center"
                android:text="AR"
                android:textColor="#3A3A3A"
                android:textSize="@dimen/main_title_size"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/userEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="user@gmail.com"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/sidebar_email_size"/>

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnNewBooking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:backgroundTint="@android:color/transparent"
            android:drawablePadding="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="New Booking"
            android:textAllCaps="false"
            android:textColor="#FFEB3B"
            android:textSize="13sp"
            android:textStyle="bold"
            app:drawableStartCompat="@drawable/ic_calendar"
            app:drawableTint="@android:color/white" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnBarbers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:backgroundTint="@android:color/transparent"
            android:drawablePadding="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Barbers"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/sidebar_text_size"
            app:drawableStartCompat="@drawable/ic_barber"
            app:drawableTint="@color/white" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnServices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:backgroundTint="@android:color/transparent"
            android:drawablePadding="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Services"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/sidebar_text_size"
            app:drawableStartCompat="@drawable/ic_scissors"
            app:drawableTint="@color/white" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnProducts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:backgroundTint="@android:color/transparent"
            android:drawablePadding="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Products"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/sidebar_text_size"
            app:drawableStartCompat="@drawable/ic_products"
            app:drawableTint="#F4F6F4" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:backgroundTint="@android:color/transparent"
            android:drawablePadding="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="History"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/sidebar_text_size"
            app:drawableStartCompat="@drawable/ic_history"
            app:drawableTint="#FFFFFF" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRatings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:backgroundTint="@android:color/transparent"
            android:drawablePadding="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Ratings"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/sidebar_text_size"
            app:drawableStartCompat="@drawable/ic_star"
            app:drawableTint="#FFFFFF" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnHaircutFinder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@android:color/transparent"
            android:drawablePadding="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Haircut Finder"
            android:textAllCaps="false"
            android:textColor="#FFEB3B"
            android:textSize="@dimen/sidebar_text_size"
            android:textStyle="bold"
            app:drawableStartCompat="@drawable/ic_camera"
            app:drawableTint="#FFEB3B" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDarkMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:backgroundTint="@android:color/transparent"
            android:drawablePadding="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Dark Mode"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/sidebar_text_size" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#C62828"
            android:drawablePadding="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Logout"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/sidebar_text_size"
            app:drawableStartCompat="@drawable/ic_logout"
            app:drawableTint="#FFFFFF" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/contentArea"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="?attr/colorSurface">

        <LinearLayout
            android:tag="stickyHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="?attr/colorSurface"
            android:elevation="4dp"
            android:outlineProvider="bounds"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvPageTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Book an Appointment"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/main_title_size"
                android:textStyle="bold"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutline"
            android:alpha="0.15"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Username *"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/label_text_size"
                            android:textStyle="bold"/>

                        <EditText
                            android:id="@+id/etUsername"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/edit_text_background_removebg_preview"
                            android:gravity="center_vertical"
                            android:hint="Enter your name"
                            android:inputType="textPersonName"
                            android:paddingStart="20dp"
                            android:paddingTop="0dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="0dp"
                            android:textColor="?attr/colorOnSurface"
                            android:textColorHint="?attr/colorOnSurface"
                            android:textSize="@dimen/label_text_size"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select Barber *"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/label_text_size"
                            android:textStyle="bold"/>

                        <Spinner
                            android:id="@+id/spinnerBarber"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/edit_text_background_removebg_preview"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select Service *"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/label_text_size"
                            android:textStyle="bold"/>

                        <Spinner
                            android:id="@+id/spinnerService"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/edit_text_background_removebg_preview"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select Date * (Must be at least 1 day in advance)"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/label_text_size"
                            android:textStyle="bold"/>

                        <EditText
                            android:id="@+id/etDate"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/edit_text_background_removebg_preview"
                            android:clickable="true"
                            android:focusable="false"
                            android:gravity="center_vertical"
                            android:hint="mm/dd/yyyy"
                            android:inputType="none"
                            android:paddingStart="20dp"
                            android:paddingTop="0dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="0dp"
                            android:textColor="?attr/colorOnSurface"
                            android:textColorHint="?attr/colorOnSurface"
                            android:textSize="@dimen/label_text_size"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select Time Slot *"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/label_text_size"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvTimeSlotNote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="16dp"
                            android:background="?attr/colorPrimaryContainer"
                            android:gravity="center"
                            android:padding="16dp"
                            android:text="Please select a barber and date first"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/label_text_size"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Amount:"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/label_text_size"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvTotalAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="16dp"
                            android:text="&#8369;0.00"
                            android:textColor="#6366F1"
                            android:textSize="@dimen/main_title_size"
                            android:textStyle="bold"/>

                        <Button
                            android:id="@+id/btnBookNow"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/button_height"
                            android:backgroundTint="#6366F1"
                            android:text="Confirm Booking"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="@dimen/button_text_size"
                            android:textStyle="bold"
                            app:cornerRadius="8dp"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</LinearLayout>