<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="GCash Payment"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#007AFF"/>

            <TextView
                android:id="@+id/tvAmountToPay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#007AFF"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F0F8FF"
            android:padding="14dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Payment Instructions"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#007AFF"/>
            </LinearLayout>



            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Scan the QR code below using your GCash app"
                android:textSize="12sp"
                android:textColor="#333333"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. Complete the payment in GCash"
                android:textSize="12sp"
                android:textColor="#333333"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3. Take a screenshot of the payment confirmation"
                android:textSize="12sp"
                android:textColor="#333333"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4. Upload the screenshot below to confirm your booking"
                android:textSize="12sp"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STRICTLY NO REFUND"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#E53935"/>
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#DDDDDD"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  scan this QR  "
                android:textSize="11sp"
                android:textColor="#AAAAAA"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#DDDDDD"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/ivGcashQr"
            android:layout_width="260dp"
            android:layout_height="400dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:scaleType="fitCenter"
            android:src="@drawable/gcash_qr"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload Payment Screenshot *"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnChooseScreenshot"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="📎 Choose Screenshot"
            android:textAllCaps="false"
            android:textColor="#007AFF"
            android:backgroundTint="#E8F4FF"
            android:layout_marginBottom="8dp"
            app:cornerRadius="8dp"/>

        <ImageView
            android:id="@+id/ivScreenshotPreview"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="12dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:background="#F5F5F5"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your booking will be confirmed once the admin verifies your payment."
            android:textSize="11sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnCancelPayment"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#888888"
                android:backgroundTint="#EEEEEE"
                app:cornerRadius="8dp"/>

            <Button
                android:id="@+id/btnConfirmPayment"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Confirm Payment"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#007AFF"
                app:cornerRadius="8dp"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>